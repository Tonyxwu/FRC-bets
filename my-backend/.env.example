# The Blue Alliance API key (get one at https://www.thebluealliance.com/apidocs)
TBA_KEY=your_tba_api_key_here

# Optional: set to true/1/yes to reset all user balances to 100 and clear all bets/pools on startup
# RESET_BALANCES_AND_BETS=true

# Optional: virtual time for testing (leave unset for real time)
# VIRTUAL_START_TIME=2025-02-20T08:00:00
# VIRTUAL_SPEED=10
